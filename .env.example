# ─── Database (Neon Postgres) ────────────────────────────────
# Pooled URL for app runtime — used by Prisma Client at request time.
DATABASE_URL=

# Direct URL (non-pooled) — used by Prisma Migrate / introspection.
# Required when DATABASE_URL points to a connection pooler (PgBouncer).
DIRECT_URL=

# ─── NextAuth ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# OAuth providers (laisser vide tant que les apps ne sont pas créées)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe ──────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys (test mode)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Set after creating the webhook endpoint in Stripe dashboard (whsec_...)
STRIPE_WEBHOOK_SECRET=

# 3 paid packs × 2 durations — create as Stripe Prices on the LPT product(s)
# All HT (tax-exclusive) — Stripe applies VAT at checkout per buyer country.
STRIPE_PRICE_BOOST_1M=     # 39 € HT  (Boost 1 mois)
STRIPE_PRICE_BOOST_4M=     # 99 € HT  (Boost 4 mois)
STRIPE_PRICE_PRO_1M=       # 79 € HT  (Pro 1 mois)
STRIPE_PRICE_PRO_4M=       # 199 € HT (Pro 4 mois)
STRIPE_PRICE_ULTRA_1M=     # 199 € HT (Ultra 1 mois)
STRIPE_PRICE_ULTRA_4M=     # 299 € HT (Ultra 4 mois)

# Legacy single-price (49€) for the old PREMIUM flow — kept while old rows exist.
STRIPE_PRICE_ID=
STRIPE_PRODUCT_ID=

# Used for Stripe success_url / cancel_url. Production = https://lpt-annonces.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Email transactionnel (Resend) ───────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Les Pépites Tech <noreply@lespepitestech.com>"

# ─── Storage (Vercel Blob ou R2/S3) ──────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Cron (Vercel) ───────────────────────────────────────────
# Used by /api/cron/* to authenticate Vercel Cron invocations.
# Generate with: openssl rand -base64 32
CRON_SECRET=
